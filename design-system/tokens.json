{
  "$schema": "https://design-tokens.org/schemas/1.0",
  "$meta": {
    "project": "oskinar.es",
    "theme": "Split Dark Gunmetal + Orange Coral",
    "source": "style.css original — extraído 2026-04-19",
    "version": "1.0.0"
  },

  "color": {
    "bg": {
      "left":    { "$value": "#1E1F26", "$description": "Fondo base principal — Gris Plomo Profundo" },
      "right":   { "$value": "#252630", "$description": "Tarjetas y lado derecho del split" },
      "glass":   { "$value": "#2A2C36", "$description": "Tarjeta flotante del hero (glass-card)" },
      "footer":  { "$value": "#15161A", "$description": "Footer profundo — gradiente final" }
    },
    "accent": {
      "primary":  { "$value": "#FF5757", "$description": "Naranja Coral Intenso — color principal de acento" },
      "soft":     { "$value": "#FF8A65", "$description": "Naranja degradado — final del gradiente" },
      "glow":     { "$value": "rgba(255, 87, 87, 0.25)", "$description": "Brillo ambiental de fondo" },
      "hover":    { "$value": "#FF4040", "$description": "Estado hover del botón primario" },
      "bg-tint":  { "$value": "rgba(255, 87, 87, 0.08)", "$description": "Fondo muy suave para tags de tecnología" },
      "bg-tint-strong": { "$value": "rgba(255, 87, 87, 0.10)", "$description": "Fondo para badges y stack items activos" }
    },
    "text": {
      "main":     { "$value": "#FFFFFF", "$description": "Texto principal" },
      "muted":    { "$value": "#9DA0B0", "$description": "Texto secundario — Gris medio azulado" }
    },
    "border": {
      "subtle":   { "$value": "rgba(255, 255, 255, 0.05)", "$description": "Borde mínimo para tarjetas" },
      "hover":    { "$value": "rgba(255, 87, 87, 0.30)", "$description": "Borde en hover de tarjetas" },
      "btn":      { "$value": "rgba(255, 255, 255, 0.15)", "$description": "Borde botón outline" }
    },
    "syntax": {
      "keyword":  { "$value": "#FF5757", "$description": "Palabras clave PHP/JS — mismo que accent" },
      "string":   { "$value": "#69F0AE", "$description": "Strings — Mint Green" },
      "function": { "$value": "#7C4DFF", "$description": "Funciones/booleanos — Violet" },
      "variable": { "$value": "#FFD740", "$description": "Variables — Amber Yellow" },
      "comment":  { "$value": "#5C6070", "$description": "Comentarios — gris desaturado" }
    }
  },

  "gradient": {
    "accent":     { "$value": "linear-gradient(135deg, #FF5757 0%, #FF8A65 100%)" },
    "hero-split": { "$value": "linear-gradient(90deg, #1E1F26 0%, #1E1F26 50%, #252630 50%, #252630 100%)" },
    "footer":     { "$value": "linear-gradient(to bottom, #1E1F26, #15161A)" },
    "divider-shadow": { "$value": "linear-gradient(to right, rgba(0,0,0,0.2), rgba(0,0,0,0))" },
    "glow-ambient": { "$value": "radial-gradient(circle, rgba(255,87,87,0.25) 0%, rgba(0,0,0,0) 70%)" }
  },

  "typography": {
    "font-main":  { "$value": "'Plus Jakarta Sans', sans-serif" },
    "font-mono":  { "$value": "'Courier New', monospace" },
    "weights": {
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "bold":     { "$value": 700 },
      "black":    { "$value": 800 }
    },
    "sizes": {
      "h1-hero":  { "$value": "clamp(3rem, 5vw, 5rem)" },
      "h2":       { "$value": "3rem" },
      "h2-footer":{ "$value": "2.5rem" },
      "big-email":{ "$value": "clamp(2rem, 5vw, 4rem)" },
      "body":     { "$value": "1rem" },
      "body-lg":  { "$value": "1.1rem" },
      "body-sm":  { "$value": "0.95rem" },
      "badge":    { "$value": "0.75rem" },
      "tag":      { "$value": "0.75rem" },
      "nav":      { "$value": "0.95rem" }
    },
    "tracking": {
      "h1":       { "$value": "-1px" },
      "badge":    { "$value": "1.5px" }
    },
    "leading": {
      "heading":  { "$value": 1.1 },
      "body":     { "$value": 1.6 }
    }
  },

  "spacing": {
    "section":         { "$value": "120px 0" },
    "section-header":  { "$value": "80px" },
    "container-width": { "$value": "1200px" },
    "nav-height":      { "$value": "90px" },
    "hero-padding-h":  { "$value": "60px" },
    "card-padding":    { "$value": "30px" },
    "glass-padding":   { "$value": "40px" },
    "btn-padding":     { "$value": "12px 32px" },
    "badge-padding":   { "$value": "6px 12px" },
    "tag-padding":     { "$value": "4px 8px" },
    "stack-padding":   { "$value": "20px" }
  },

  "border-radius": {
    "default": { "$value": "6px", "$description": "Radio base — estilo tech cuadrado" },
    "card":    { "$value": "8px" },
    "badge":   { "$value": "4px" },
    "tag":     { "$value": "4px" }
  },

  "shadow": {
    "card":         { "$value": "0 20px 50px rgba(0, 0, 0, 0.3)" },
    "btn-primary":  { "$value": "0 4px 15px rgba(255, 87, 87, 0.2)" },
    "btn-hover":    { "$value": "0 8px 25px rgba(255, 87, 87, 0.35)" },
    "card-hover":   { "$value": "0 20px 40px rgba(0, 0, 0, 0.4)" }
  },

  "animation": {
    "float-card": {
      "duration":  { "$value": "8s" },
      "easing":    { "$value": "ease-in-out" },
      "iteration": { "$value": "infinite" },
      "transform": { "$value": "translateY(-15px)" }
    },
    "pulse-glow": {
      "duration":  { "$value": "10s" },
      "easing":    { "$value": "alternate" },
      "transform": { "$value": "scale(1.1)" }
    },
    "transition-std": { "$value": "0.3s ease" },
    "transition-fast":{ "$value": "0.2s ease" }
  },

  "effects": {
    "navbar-blur":    { "$value": "blur(8px)" },
    "glow-blur":      { "$value": "blur(100px)" },
    "glow-opacity":   { "$value": 0.5 },
    "center-guide":   { "$value": "rgba(255, 255, 255, 0.03)" }
  },

  "breakpoints": {
    "mobile": { "$value": "992px", "$description": "Punto de quiebre para colapsar split y nav" }
  }
}
